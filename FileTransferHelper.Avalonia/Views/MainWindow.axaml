<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FileTransferHelper.ViewModels"
        xmlns:models="using:FileTransferHelper.Models"
        xmlns:converters="using:Avalonia.Controls.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="FileTransferHelper.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="980"
        Height="680"
        MinWidth="860"
        MinHeight="600"
        Icon="/Assets/avalonia-logo.ico"
        Title="FileTransferHelper">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Resources>
        <Geometry x:Key="RemoteFolderIcon">M 4,8 L 4,28 C 4,29.1 4.9,30 6,30 L 38,30 C 39.1,30 40,29.1 40,28 L 40,12 C 40,10.9 39.1,10 38,10 L 22,10 L 18,6 L 6,6 C 4.9,6 4,6.9 4,8 Z</Geometry>
        <Geometry x:Key="RemoteFolderOpenIcon">M 4,16 L 4,28 C 4,29.1 4.9,30 6,30 L 38,30 C 39.1,30 40,29.1 40,28 L 40,18 L 8,18 C 5.8,18 4,17.1 4,16 Z M 6,12 L 18,12 L 22,8 L 38,8 C 39.8,8 41,9.4 41,11 L 41,16 L 4,16 L 6,12 Z</Geometry>
        <Geometry x:Key="RemoteFileIcon">M 8,4 L 24,4 L 32,12 L 32,36 C 32,37.1 31.1,38 30,38 L 8,38 C 6.9,38 6,37.1 6,36 L 6,6 C 6,4.9 6.9,4 8,4 Z</Geometry>
        <Geometry x:Key="RemoteFileFoldIcon">M 24,4 L 24,12 L 32,12 Z</Geometry>
        <Geometry x:Key="TreeChevronIcon">M 0,0 L 4,4 L 0,8</Geometry>
        <Geometry x:Key="TreeFolderIcon">M 0,4 L 0,12 L 12,12 L 12,6 L 7,6 L 5,4 Z</Geometry>
        <Geometry x:Key="TreeFolderOpenIcon">M 0,7 L 0,12 L 12,12 L 12,9 L 2,9 C 0.8,9 0,8.4 0,7 Z M 1,5 L 5,5 L 6,4 L 11,4 C 12,4 12,5.2 12,6 L 12,7 L 0,7 L 1,5 Z</Geometry>
        <SolidColorBrush x:Key="TreeChevronBrush" Color="#B8B8B8"/>
        <SolidColorBrush x:Key="TreeChevronHoverBrush" Color="#666666"/>

        <converters:MarginMultiplierConverter x:Key="CompactTreeIndentConverter"
                                                Indent="12"
                                                Left="True"/>

        <ControlTheme x:Key="CompactRemoteTreeChevron" TargetType="ToggleButton">
            <Setter Property="Width" Value="7"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TreeChevronBrush}"/>
            <Setter Property="Template">
                <ControlTemplate TargetType="ToggleButton">
                    <Panel Background="Transparent">
                        <Viewbox x:Name="ChevronBox"
                                 Width="5"
                                 Height="5"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 RenderTransformOrigin="50%,50%">
                            <Path Data="{StaticResource TreeChevronIcon}"
                                  Stroke="{TemplateBinding Foreground}"
                                  StrokeThickness="1"
                                  StrokeLineCap="Round"
                                  StrokeJoin="Round"
                                  Fill="Transparent"/>
                        </Viewbox>
                    </Panel>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover">
                <Setter Property="Foreground" Value="{StaticResource TreeChevronHoverBrush}"/>
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="Foreground" Value="{StaticResource TreeChevronHoverBrush}"/>
            </Style>
            <Style Selector="^:checked /template/ Viewbox#ChevronBox">
                <Setter Property="RenderTransform">
                    <RotateTransform Angle="90"/>
                </Setter>
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="CompactRemoteTreeViewItem" TargetType="TreeViewItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinHeight" Value="18"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <ControlTemplate TargetType="TreeViewItem">
                    <StackPanel>
                        <Border Name="PART_LayoutRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                MinHeight="18"
                                ClipToBounds="False"
                                Padding="0">
                            <Grid Name="PART_Header"
                                  MinHeight="18"
                                  ColumnDefinitions="Auto,*"
                                  VerticalAlignment="Stretch"
                                  Margin="{TemplateBinding Level, Mode=OneWay, Converter={StaticResource CompactTreeIndentConverter}}">
                                <ToggleButton Name="PART_ExpandCollapseChevron"
                                              Grid.Column="0"
                                              VerticalAlignment="Center"
                                              Theme="{StaticResource CompactRemoteTreeChevron}"
                                              Focusable="False"
                                              IsChecked="{TemplateBinding IsExpanded, Mode=TwoWay}"/>
                                <ContentPresenter Name="PART_HeaderPresenter"
                                                  Grid.Column="1"
                                                  Focusable="False"
                                                  Content="{TemplateBinding Header}"
                                                  ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                  VerticalAlignment="Center"
                                                  VerticalContentAlignment="Center"
                                                  HorizontalContentAlignment="Left"
                                                  ClipToBounds="False"
                                                  Margin="0"/>
                            </Grid>
                        </Border>
                        <ItemsPresenter Name="PART_ItemsPresenter"
                                        IsVisible="{TemplateBinding IsExpanded}"/>
                    </StackPanel>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:selected /template/ Border#PART_LayoutRoot">
                <Setter Property="Background" Value="{DynamicResource SystemHighlightBrush}"/>
            </Style>
            <Style Selector="^:selected /template/ ContentPresenter#PART_HeaderPresenter">
                <Setter Property="Foreground" Value="{DynamicResource SystemHighlightColorBrush}"/>
            </Style>
            <Style Selector="^ /template/ Border#PART_LayoutRoot:pointerover">
                <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}"/>
            </Style>
        </ControlTheme>
    </Window.Resources>

    <Grid Margin="14"
          RowDefinitions="Auto,*,Auto"
          RowSpacing="8">
        <Border Grid.Row="0"
                x:Name="ConnectionPanel"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8,6">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto,Auto"
                  ColumnSpacing="8">
                <TextBlock Grid.Column="0"
                           Text="Raspberry Pi"
                           FontWeight="SemiBold"
                           FontSize="12"
                           VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1"
                          MinWidth="160"
                          ItemsSource="{Binding Hosts}"
                          SelectedItem="{Binding SelectedHost, Mode=TwoWay}"
                          PlaceholderText="Ingen enhet hittad"
                          VerticalAlignment="Center">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="models:HostCandidate">
                            <TextBlock Text="{Binding Label}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock Grid.Column="2"
                           Text="Användare"
                           FontSize="11"
                           VerticalAlignment="Center"
                           IsVisible="{Binding ShowConnectionControls}"/>
                <TextBox Grid.Column="3"
                         Width="110"
                         FontSize="11"
                         VerticalAlignment="Center"
                         IsVisible="{Binding ShowConnectionControls}"
                         Text="{Binding Username, Mode=TwoWay}"/>
                <TextBlock Grid.Column="4"
                           Text="Lösenord"
                           FontSize="11"
                           VerticalAlignment="Center"
                           IsVisible="{Binding ShowConnectionControls}"/>
                <TextBox Grid.Column="5"
                         Width="130"
                         FontSize="11"
                         PasswordChar="*"
                         VerticalAlignment="Center"
                         IsVisible="{Binding ShowConnectionControls}"
                         Text="{Binding Password, Mode=TwoWay}"
                         KeyDown="PasswordBox_KeyDown"/>
                <Button Grid.Column="6"
                        Content="Anslut"
                        MinWidth="72"
                        VerticalAlignment="Center"
                        IsVisible="{Binding ShowConnectionControls}"
                        Command="{Binding ConnectCommand}"
                        IsEnabled="{Binding !IsConnecting}"/>
                <TextBlock Grid.Column="7"
                           MinWidth="140"
                           FontSize="11"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Text="{Binding ConnectionStatusText}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              x:Name="MainPanelsGrid"
              ColumnSpacing="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding LocalPanelColumnWidth}" MinWidth="280"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*" MinWidth="280"/>
            </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="6">
            <Grid RowDefinitions="Auto,*"
                  RowSpacing="4">
                <TextBlock Grid.Row="0"
                           FontWeight="SemiBold"
                           FontSize="12"
                           Text="Filer från den här datorn"/>
                <Grid Grid.Row="1"
                      RowDefinitions="Auto,*"
                      RowSpacing="4">
                    <Border Grid.Row="0"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="4,2">
                        <TextBox x:Name="LocalPathBox"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="11"
                                 MinHeight="0"
                                 Padding="2,1"
                                 Watermark="Sökväg — tryck Enter för att öppna"
                                 Text="{Binding LocalPath, Mode=TwoWay}"
                                 KeyDown="LocalPathBox_KeyDown"/>
                    </Border>

                    <Grid Grid.Row="1"
                          x:Name="LocalExplorerGrid"
                          ClipToBounds="True"
                          RowDefinitions="*">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{Binding LocalTreeColumnWidth}" MinWidth="80"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Öppna"
                                          Command="{Binding OpenSelectedLocalEntryCommand}"/>
                                <Separator/>
                                <MenuItem Header="Ny mapp"
                                          Command="{Binding CreateLocalFolderCommand}"/>
                                <MenuItem Header="Ta bort"
                                          Command="{Binding DeleteSelectedLocalItemCommand}"
                                          IsEnabled="{Binding !IsDeletingLocalItem}"/>
                                <Separator/>
                                <MenuItem Header="Uppdatera"
                                          Command="{Binding RefreshLocalDirsCommand}"/>
                                <Separator/>
                                <MenuItem Header="Hem"
                                          Command="{Binding LocalHomeCommand}"/>
                                <MenuItem Header="Upp en nivå"
                                          Command="{Binding LocalUpCommand}"/>
                            </ContextMenu>
                        </Grid.ContextMenu>

                        <Border Grid.Column="0"
                                ZIndex="0"
                                ClipToBounds="True"
                                Padding="0,0,4,0"
                                Background="{DynamicResource SystemControlChromeMediumLowBrush}">
                            <TreeView x:Name="LocalTree"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ItemsSource="{Binding LocalTreeRoots}"
                                      SelectedItem="{Binding SelectedLocalTreeNode, Mode=TwoWay}"
                                      SelectedItems="{Binding SelectedLocalTreeNodes, Mode=TwoWay}"
                                      SelectionMode="Multiple"
                                      ItemContainerTheme="{StaticResource CompactRemoteTreeViewItem}"
                                      Tapped="LocalTreeItem_Tapped">
                            <TreeView.Styles>
                                <Style Selector="TreeViewItem" x:DataType="models:LocalTreeNode">
                                    <Setter Property="MinHeight" Value="18"/>
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                    <Setter Property="IsVisible" Value="{Binding !IsPlaceholder}"/>
                                </Style>
                            </TreeView.Styles>
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate DataType="models:LocalTreeNode"
                                                    ItemsSource="{Binding Children}">
                                    <Grid MinHeight="18"
                                          ColumnDefinitions="Auto,Auto"
                                          VerticalAlignment="Center"
                                          IsVisible="{Binding !IsPlaceholder}">
                                        <Border Grid.Column="0"
                                                Width="12"
                                                Height="12"
                                                Margin="0,0,2,0"
                                                VerticalAlignment="Center">
                                            <Path Data="{StaticResource TreeFolderIcon}"
                                                  Fill="#F4B740"
                                                  Stretch="Uniform"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   TextWrapping="NoWrap"
                                                   Text="{Binding Name}"/>
                                    </Grid>
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                            </TreeView>
                        </Border>

                        <GridSplitter x:Name="LocalTreeSplitter"
                                      Grid.Column="1"
                                      ZIndex="2"
                                      Width="1"
                                      ResizeDirection="Columns"
                                      Background="#C8C8C8"
                                      DragCompleted="LocalTreeSplitter_DragCompleted"/>

                        <Border Grid.Column="2"
                                ZIndex="1"
                                ClipToBounds="True"
                                Padding="6,0,0,0"
                                Background="{DynamicResource SystemControlChromeMediumLowBrush}">
                            <ListBox x:Name="LocalList"
                                     ItemsSource="{Binding LocalEntries}"
                                     SelectedItem="{Binding SelectedLocalEntry, Mode=TwoWay}"
                                     SelectionMode="Multiple"
                                     Background="Transparent"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                    <Setter Property="Padding" Value="2,0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="MinHeight" Value="18"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                                <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                    <Setter Property="Background" Value="{DynamicResource SystemHighlightBrush}"/>
                                    <Setter Property="CornerRadius" Value="2"/>
                                </Style>
                                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                    <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}"/>
                                    <Setter Property="CornerRadius" Value="2"/>
                                </Style>
                            </ListBox.Styles>
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:LocalEntry">
                                    <Grid ColumnDefinitions="Auto,*"
                                          Height="18"
                                          Margin="1,0"
                                          ToolTip.Tip="{Binding Name}">
                                        <Panel Grid.Column="0"
                                               Width="14"
                                               Height="14"
                                               Margin="0,0,5,0"
                                               VerticalAlignment="Center">
                                            <Path IsVisible="{Binding IsDirectory}"
                                                  Data="{StaticResource RemoteFolderIcon}"
                                                  Fill="#F4B740"
                                                  Stretch="Uniform"/>
                                            <Panel IsVisible="{Binding !IsDirectory}">
                                                <Path Data="{StaticResource RemoteFileIcon}"
                                                      Fill="#F5F5F5"
                                                      Stroke="#9E9E9E"
                                                      StrokeThickness="0.8"
                                                      Stretch="Uniform"/>
                                                <Path Data="{StaticResource RemoteFileFoldIcon}"
                                                      Fill="#BDBDBD"
                                                      Stretch="Uniform"/>
                                            </Panel>
                                        </Panel>
                                        <TextBlock Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="{Binding Name}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <GridSplitter x:Name="MainPanelSplitter"
                      Grid.Column="1"
                      ZIndex="2"
                      Width="1"
                      HorizontalAlignment="Center"
                      ResizeDirection="Columns"
                      Background="#C8C8C8"
                      DragCompleted="MainPanelSplitter_DragCompleted"/>

        <Border Grid.Column="2"
                x:Name="RemotePanel"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="6">
            <Grid RowDefinitions="Auto,*"
                  RowSpacing="4">
                <TextBlock Grid.Row="0"
                           FontWeight="SemiBold"
                           FontSize="12"
                           Text="Destination på Raspberry Pi"/>
                <Grid Grid.Row="1"
                      RowDefinitions="Auto,*"
                      RowSpacing="4">
                    <Border Grid.Row="0"
                            x:Name="RemotePathBorder"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="4,2">
                        <TextBox x:Name="RemotePathBox"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="11"
                                 MinHeight="0"
                                 Padding="2,1"
                                 Watermark="Sökväg — tryck Enter för att öppna"
                                 Text="{Binding RemotePath, Mode=TwoWay}"
                                 KeyDown="RemotePathBox_KeyDown"/>
                    </Border>

                    <Grid Grid.Row="1"
                          x:Name="RemoteExplorerGrid"
                          ClipToBounds="True"
                          RowDefinitions="*">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{Binding RemoteTreeColumnWidth}" MinWidth="80"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Öppna"
                                          Command="{Binding OpenSelectedRemoteEntryCommand}"/>
                                <Separator/>
                                <MenuItem Header="Ny mapp"
                                          Command="{Binding CreateRemoteFolderCommand}"/>
                                <MenuItem Header="Ta bort"
                                          Command="{Binding DeleteSelectedRemoteItemCommand}"
                                          IsEnabled="{Binding !IsDeletingRemoteItem}"/>
                                <Separator/>
                                <MenuItem Header="Uppdatera"
                                          Command="{Binding RefreshRemoteDirsCommand}"/>
                                <Separator/>
                                <MenuItem Header="Hem"
                                          Command="{Binding RemoteHomeCommand}"/>
                                <MenuItem Header="Upp en nivå"
                                          Command="{Binding RemoteUpCommand}"/>
                                <Separator/>
                                <MenuItem Header="Ta bort dubbletter"
                                          Command="{Binding FindRemoteDuplicatesCommand}"
                                          IsEnabled="{Binding !IsDeletingDuplicates}"/>
                            </ContextMenu>
                        </Grid.ContextMenu>

                        <Border Grid.Column="0"
                                ZIndex="0"
                                ClipToBounds="True"
                                Padding="0,0,4,0"
                                Background="{DynamicResource SystemControlChromeMediumLowBrush}">
                            <TreeView x:Name="RemoteTree"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ItemsSource="{Binding RemoteTreeRoots}"
                                      SelectedItem="{Binding SelectedRemoteTreeNode, Mode=TwoWay}"
                                      SelectedItems="{Binding SelectedRemoteTreeNodes, Mode=TwoWay}"
                                      SelectionMode="Multiple"
                                      ItemContainerTheme="{StaticResource CompactRemoteTreeViewItem}"
                                      Tapped="RemoteTreeItem_Tapped">
                            <TreeView.Styles>
                                <Style Selector="TreeViewItem" x:DataType="models:RemoteTreeNode">
                                    <Setter Property="MinHeight" Value="18"/>
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                    <Setter Property="IsVisible" Value="{Binding !IsPlaceholder}"/>
                                </Style>
                                <Style Selector="TreeViewItem.drop-target /template/ Border#PART_LayoutRoot">
                                    <Setter Property="Background" Value="#55F4B740"/>
                                </Style>
                            </TreeView.Styles>
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate DataType="models:RemoteTreeNode"
                                                    ItemsSource="{Binding Children}">
                                    <Grid MinHeight="18"
                                          ColumnDefinitions="Auto,Auto"
                                          VerticalAlignment="Center"
                                          IsVisible="{Binding !IsPlaceholder}">
                                        <Border Grid.Column="0"
                                                Width="12"
                                                Height="12"
                                                Margin="0,0,2,0"
                                                VerticalAlignment="Center">
                                            <Panel>
                                                <Path IsVisible="{Binding ShowClosedFolder}"
                                                      Data="{StaticResource TreeFolderIcon}"
                                                      Fill="#F4B740"
                                                      Stretch="Uniform"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"/>
                                                <Path IsVisible="{Binding ShowOpenFolder}"
                                                      Data="{StaticResource TreeFolderOpenIcon}"
                                                      Fill="#F4B740"
                                                      Stretch="Uniform"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"/>
                                            </Panel>
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   TextWrapping="NoWrap"
                                                   Text="{Binding Name}"/>
                                    </Grid>
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                            </TreeView>
                        </Border>

                        <GridSplitter x:Name="RemoteTreeSplitter"
                                      Grid.Column="1"
                                      ZIndex="2"
                                      Width="1"
                                      ResizeDirection="Columns"
                                      Background="#C8C8C8"
                                      DragCompleted="RemoteTreeSplitter_DragCompleted"/>

                        <Border Grid.Column="2"
                                ZIndex="1"
                                ClipToBounds="True"
                                Padding="6,0,0,0"
                                Background="{DynamicResource SystemControlChromeMediumLowBrush}">
                            <ListBox x:Name="RemoteList"
                                     ItemsSource="{Binding RemoteEntries}"
                                     SelectedItem="{Binding SelectedRemoteEntry, Mode=TwoWay}"
                                     Background="Transparent"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                    <Setter Property="Padding" Value="2,0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="MinHeight" Value="18"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                                <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                    <Setter Property="Background" Value="{DynamicResource SystemHighlightBrush}"/>
                                    <Setter Property="CornerRadius" Value="2"/>
                                </Style>
                                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                    <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}"/>
                                    <Setter Property="CornerRadius" Value="2"/>
                                </Style>
                                <Style Selector="ListBoxItem.drop-target /template/ ContentPresenter">
                                    <Setter Property="Background" Value="#55F4B740"/>
                                    <Setter Property="CornerRadius" Value="2"/>
                                </Style>
                            </ListBox.Styles>
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="models:RemoteEntry">
                                    <Grid ColumnDefinitions="Auto,*"
                                          Height="18"
                                          Margin="1,0"
                                          ToolTip.Tip="{Binding Name}"
                                          DoubleTapped="RemoteItem_DoubleTapped">
                                        <Panel Grid.Column="0"
                                               Width="14"
                                               Height="14"
                                               Margin="0,0,5,0"
                                               VerticalAlignment="Center">
                                            <Path IsVisible="{Binding ShowClosedFolder}"
                                                  Data="{StaticResource RemoteFolderIcon}"
                                                  Fill="#F4B740"
                                                  Stretch="Uniform"/>
                                            <Path IsVisible="{Binding ShowOpenFolder}"
                                                  Data="{StaticResource RemoteFolderOpenIcon}"
                                                  Fill="#F4B740"
                                                  Stretch="Uniform"/>
                                            <Panel IsVisible="{Binding !IsDirectory}">
                                                <Path Data="{StaticResource RemoteFileIcon}"
                                                      Fill="#F5F5F5"
                                                      Stroke="#9E9E9E"
                                                      StrokeThickness="0.8"
                                                      Stretch="Uniform"/>
                                                <Path Data="{StaticResource RemoteFileFoldIcon}"
                                                      Fill="#BDBDBD"
                                                      Stretch="Uniform"/>
                                            </Panel>
                                        </Panel>
                                        <TextBlock Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="{Binding Name}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
        </Grid>

        <Border Grid.Row="2"
                MinHeight="32"
                Background="{DynamicResource SystemControlChromeMediumLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8,6">
            <Grid RowDefinitions="Auto,Auto"
                  RowSpacing="4">
                <TextBlock Grid.Row="0"
                           FontSize="11"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Text="{Binding Status}"/>
                <Grid Grid.Row="1"
                      IsVisible="{Binding IsTransferring}"
                      ColumnDefinitions="*,Auto,Auto"
                      ColumnSpacing="10">
                    <ProgressBar Grid.Column="0"
                                 Minimum="0"
                                 Maximum="100"
                                 Height="6"
                                 VerticalAlignment="Center"
                                 Value="{Binding ProgressValue}"/>
                    <TextBlock Grid.Column="1"
                               MinWidth="88"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Text="{Binding ProgressText}"/>
                    <TextBlock Grid.Column="2"
                               MinWidth="72"
                               FontSize="11"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Text="{Binding TransferSpeedText}"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
