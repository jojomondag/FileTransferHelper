<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FileTransferHelper.ViewModels"
        xmlns:models="using:FileTransferHelper.Models"
        xmlns:converters="using:Avalonia.Controls.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="FileTransferHelper.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="980"
        Height="680"
        MinWidth="860"
        MinHeight="600"
        Icon="/Assets/avalonia-logo.ico"
        Title="FileTransferHelper">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Resources>
        <Geometry x:Key="RemoteFolderIcon">M 4,8 L 4,28 C 4,29.1 4.9,30 6,30 L 38,30 C 39.1,30 40,29.1 40,28 L 40,12 C 40,10.9 39.1,10 38,10 L 22,10 L 18,6 L 6,6 C 4.9,6 4,6.9 4,8 Z</Geometry>
        <Geometry x:Key="RemoteFolderOpenIcon">M 4,16 L 4,28 C 4,29.1 4.9,30 6,30 L 38,30 C 39.1,30 40,29.1 40,28 L 40,18 L 8,18 C 5.8,18 4,17.1 4,16 Z M 6,12 L 18,12 L 22,8 L 38,8 C 39.8,8 41,9.4 41,11 L 41,16 L 4,16 L 6,12 Z</Geometry>
        <Geometry x:Key="RemoteFileIcon">M 8,4 L 24,4 L 32,12 L 32,36 C 32,37.1 31.1,38 30,38 L 8,38 C 6.9,38 6,37.1 6,36 L 6,6 C 6,4.9 6.9,4 8,4 Z</Geometry>
        <Geometry x:Key="RemoteFileFoldIcon">M 24,4 L 24,12 L 32,12 Z</Geometry>
        <Geometry x:Key="TreeChevronIcon">M 0,0 L 4,4 L 0,8</Geometry>
        <Geometry x:Key="ConnectionChevronIcon">M 1,2 L 14,11 L 27,2</Geometry>
        <Geometry x:Key="EyeIcon">M 1,8 C 4,3 8,1.5 12,1.5 C 16,1.5 20,3 23,8 C 20,13 16,14.5 12,14.5 C 8,14.5 4,13 1,8 Z M 12,5 C 10.3,5 9,6.3 9,8 C 9,9.7 10.3,11 12,11 C 13.7,11 15,9.7 15,8 C 15,6.3 13.7,5 12,5 Z</Geometry>
        <Geometry x:Key="TreeFolderIcon">M 0,4 L 0,12 L 12,12 L 12,6 L 7,6 L 5,4 Z</Geometry>
        <Geometry x:Key="TreeFolderOpenIcon">M 0,7 L 0,12 L 12,12 L 12,9 L 2,9 C 0.8,9 0,8.4 0,7 Z M 1,5 L 5,5 L 6,4 L 11,4 C 12,4 12,5.2 12,6 L 12,7 L 0,7 L 1,5 Z</Geometry>
        <Geometry x:Key="CancelTransferIcon">M 4,4 L 12,12 M 12,4 L 4,12</Geometry>
        <SolidColorBrush x:Key="TreeChevronBrush" Color="#B8B8B8"/>
        <SolidColorBrush x:Key="TreeChevronHoverBrush" Color="#666666"/>

        <converters:MarginMultiplierConverter x:Key="CompactTreeIndentConverter"
                                                Indent="12"
                                                Left="True"/>

        <ControlTheme x:Key="CompactRemoteTreeChevron" TargetType="ToggleButton">
            <Setter Property="Width" Value="7"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TreeChevronBrush}"/>
            <Setter Property="Template">
                <ControlTemplate TargetType="ToggleButton">
                    <Panel Background="Transparent">
                        <Viewbox x:Name="ChevronBox"
                                 Width="5"
                                 Height="5"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 RenderTransformOrigin="50%,50%">
                            <Path Data="{StaticResource TreeChevronIcon}"
                                  Stroke="{TemplateBinding Foreground}"
                                  StrokeThickness="1"
                                  StrokeLineCap="Round"
                                  StrokeJoin="Round"
                                  Fill="Transparent"/>
                        </Viewbox>
                    </Panel>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover">
                <Setter Property="Foreground" Value="{StaticResource TreeChevronHoverBrush}"/>
            </Style>
            <Style Selector="^:pressed">
                <Setter Property="Foreground" Value="{StaticResource TreeChevronHoverBrush}"/>
            </Style>
            <Style Selector="^:checked /template/ Viewbox#ChevronBox">
                <Setter Property="RenderTransform">
                    <RotateTransform Angle="90"/>
                </Setter>
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="ConnectionPanelChevron" TargetType="ToggleButton">
            <Setter Property="Width" Value="64"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TreeChevronBrush}"/>
            <Setter Property="Template">
                <ControlTemplate TargetType="ToggleButton">
                    <Panel Background="Transparent">
                        <Viewbox x:Name="ChevronBox"
                                 Width="30"
                                 Height="13"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 RenderTransformOrigin="50%,50%">
                            <Path Data="{StaticResource ConnectionChevronIcon}"
                                  Stroke="{TemplateBinding Foreground}"
                                  StrokeThickness="2.4"
                                  StrokeLineCap="Round"
                                  StrokeJoin="Round"
                                  Fill="Transparent"/>
                        </Viewbox>
                    </Panel>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover">
                <Setter Property="Foreground" Value="{StaticResource TreeChevronHoverBrush}"/>
            </Style>
            <Style Selector="^:checked /template/ Viewbox#ChevronBox">
                <Setter Property="RenderTransform">
                    <RotateTransform Angle="180"/>
                </Setter>
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="ConnectionColumnEyeToggle" TargetType="ToggleButton">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate TargetType="ToggleButton">
                    <Panel Background="Transparent">
                        <Viewbox Width="14"
                                 Height="9"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center">
                            <Path Data="{StaticResource EyeIcon}"
                                  Fill="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                  Stretch="Uniform"
                                  Opacity="0.85"/>
                        </Viewbox>
                    </Panel>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:checked /template/ Path">
                <Setter Property="Opacity" Value="1"/>
            </Style>
            <Style Selector="^:not(:checked) /template/ Path">
                <Setter Property="Opacity" Value="0.35"/>
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="CompactRemoteTreeViewItem" TargetType="TreeViewItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinHeight" Value="18"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <ControlTemplate TargetType="TreeViewItem">
                    <StackPanel>
                        <Border Name="PART_LayoutRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                MinHeight="18"
                                ClipToBounds="False"
                                Padding="0">
                            <Grid Name="PART_Header"
                                  MinHeight="18"
                                  ColumnDefinitions="Auto,*"
                                  VerticalAlignment="Stretch"
                                  Margin="{TemplateBinding Level, Mode=OneWay, Converter={StaticResource CompactTreeIndentConverter}}">
                                <ToggleButton Name="PART_ExpandCollapseChevron"
                                              Grid.Column="0"
                                              VerticalAlignment="Center"
                                              Theme="{StaticResource CompactRemoteTreeChevron}"
                                              Focusable="False"
                                              IsChecked="{TemplateBinding IsExpanded, Mode=TwoWay}"/>
                                <ContentPresenter Name="PART_HeaderPresenter"
                                                  Grid.Column="1"
                                                  Focusable="False"
                                                  Content="{TemplateBinding Header}"
                                                  ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                  VerticalAlignment="Center"
                                                  VerticalContentAlignment="Center"
                                                  HorizontalContentAlignment="Left"
                                                  ClipToBounds="False"
                                                  Margin="0"/>
                            </Grid>
                        </Border>
                        <ItemsPresenter Name="PART_ItemsPresenter"
                                        IsVisible="{TemplateBinding IsExpanded}"/>
                    </StackPanel>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:selected /template/ Border#PART_LayoutRoot">
                <Setter Property="Background" Value="{DynamicResource TreeViewItemBackgroundSelected}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource TreeViewItemBorderBrushSelected}"/>
            </Style>
            <Style Selector="^:selected /template/ ContentPresenter#PART_HeaderPresenter">
                <Setter Property="Foreground" Value="{DynamicResource TreeViewItemForegroundSelected}"/>
            </Style>
            <Style Selector="^:selected:pointerover /template/ Border#PART_LayoutRoot">
                <Setter Property="Background" Value="{DynamicResource TreeViewItemBackgroundSelectedPointerOver}"/>
            </Style>
            <Style Selector="^ /template/ Border#PART_LayoutRoot:pointerover">
                <Setter Property="Background" Value="{DynamicResource TreeViewItemBackgroundPointerOver}"/>
            </Style>
        </ControlTheme>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TextBox.connection-credential">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
    </Window.Styles>

    <Grid Margin="14"
          RowDefinitions="Auto,*"
          RowSpacing="8">
        <Border Grid.Row="0"
                x:Name="ConnectionPanel"
                IsVisible="{Binding IsConnectionPanelExpanded}"
                BorderThickness="0"
                Padding="0,0,0,2">
            <Grid>
                <StackPanel Spacing="6">
                    <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="6"
                            Background="{DynamicResource SystemControlChromeMediumLowBrush}">
                        <Grid HorizontalAlignment="Center"
                              RowDefinitions="Auto,*"
                              RowSpacing="2"
                              IsSharedSizeScope="True">
                            <Grid Grid.Row="0"
                                  ColumnSpacing="10"
                                  MinHeight="26"
                                  VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="ConnDevice"/>
                                    <ColumnDefinition Width="Auto" MinWidth="110" SharedSizeGroup="ConnAddress"/>
                                    <ColumnDefinition Width="Auto" MinWidth="72" SharedSizeGroup="ConnStatus"/>
                                    <ColumnDefinition Width="Auto" MinWidth="104" SharedSizeGroup="ConnUser"/>
                                    <ColumnDefinition Width="Auto" MinWidth="104" SharedSizeGroup="ConnPass"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="ConnAction"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0"
                                            Orientation="Horizontal"
                                            Spacing="5"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <ToggleButton Theme="{StaticResource ConnectionColumnEyeToggle}"
                                                  IsChecked="{Binding IsConnectionSecretsVisible, Mode=TwoWay}"
                                                  ToolTip.Tip="Visa/dölj adresser, användare och lösenord"/>
                                    <TextBlock Text="Enheter"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="5"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Adress"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <ToggleButton Theme="{StaticResource ConnectionColumnEyeToggle}"
                                                  IsChecked="{Binding IsConnectionAddressVisible, Mode=TwoWay}"
                                                  ToolTip.Tip="Visa/dölj adresser"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="Status"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="3"
                                            Orientation="Horizontal"
                                            Spacing="5"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Användare"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <ToggleButton Theme="{StaticResource ConnectionColumnEyeToggle}"
                                                  IsChecked="{Binding IsConnectionUsernameVisible, Mode=TwoWay}"
                                                  ToolTip.Tip="Visa/dölj användare"/>
                                </StackPanel>
                                <StackPanel Grid.Column="4"
                                            Orientation="Horizontal"
                                            Spacing="5"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="Lösenord"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <ToggleButton Theme="{StaticResource ConnectionColumnEyeToggle}"
                                                  IsChecked="{Binding IsConnectionPasswordVisible, Mode=TwoWay}"
                                                  ToolTip.Tip="Visa/dölj lösenord"/>
                                </StackPanel>
                                <Border Grid.Column="5"
                                        MinWidth="64"
                                        Height="1"
                                        Opacity="0"/>
                            </Grid>
                            <ItemsControl Grid.Row="1"
                                          HorizontalAlignment="Center"
                                          ItemsSource="{Binding ConnectionManagerEntries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:ConnectionManagerEntry">
                                        <Grid ColumnSpacing="10"
                                              MinHeight="26"
                                              VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="ConnDevice"/>
                                                <ColumnDefinition Width="Auto" MinWidth="110" SharedSizeGroup="ConnAddress"/>
                                                <ColumnDefinition Width="Auto" MinWidth="72" SharedSizeGroup="ConnStatus"/>
                                                <ColumnDefinition Width="Auto" MinWidth="104" SharedSizeGroup="ConnUser"/>
                                                <ColumnDefinition Width="Auto" MinWidth="104" SharedSizeGroup="ConnPass"/>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="ConnAction"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0"
                                                        Orientation="Horizontal"
                                                        Spacing="5"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <Border Width="18"
                                                        Height="18"
                                                        IsHitTestVisible="False"/>
                                                <TextBlock FontSize="11"
                                                           VerticalAlignment="Center"
                                                           TextAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding Name}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       IsVisible="{Binding ShowVisibleAddress}"
                                                       Text="{Binding Address}"/>
                                            <TextBlock Grid.Column="1"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       IsVisible="{Binding ShowMaskedAddress}"
                                                       Text="{Binding MaskedAddress}"/>
                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        Spacing="5"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center">
                                                <Border Width="8"
                                                        Height="8"
                                                        CornerRadius="4"
                                                        Background="{Binding StatusBrush}"/>
                                                <TextBlock FontSize="11"
                                                           VerticalAlignment="Center"
                                                           TextAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding Status}"/>
                                            </StackPanel>
                                            <Grid Grid.Column="3"
                                                  Width="104"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center">
                                                <TextBlock IsVisible="{Binding ShowVisibleReadOnlyUsername}"
                                                           FontSize="11"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding UsernameInput}"/>
                                                <TextBlock IsVisible="{Binding ShowMaskedReadOnlyUsername}"
                                                           FontSize="11"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding MaskedUsername}"/>
                                                <TextBox IsVisible="{Binding ShowVisibleUsernameInput}"
                                                         Classes="connection-credential"
                                                         HorizontalAlignment="Stretch"
                                                         Text="{Binding UsernameInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            </Grid>
                                            <Grid Grid.Column="4"
                                                  Width="104"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center">
                                                <TextBlock IsVisible="{Binding ShowVisibleReadOnlyPassword}"
                                                           FontSize="11"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding PasswordInput}"/>
                                                <TextBlock IsVisible="{Binding ShowMaskedReadOnlyPassword}"
                                                           FontSize="11"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding MaskedPassword}"/>
                                                <TextBox IsVisible="{Binding ShowVisiblePasswordInput}"
                                                         Classes="connection-credential"
                                                         HorizontalAlignment="Stretch"
                                                         Text="{Binding PasswordInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBox IsVisible="{Binding ShowMaskedPasswordInput}"
                                                         Classes="connection-credential"
                                                         HorizontalAlignment="Stretch"
                                                         PasswordChar="*"
                                                         Text="{Binding PasswordInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            </Grid>
                                            <Button Grid.Column="5"
                                                    Content="Anslut"
                                                    MinWidth="64"
                                                    FontSize="11"
                                                    Padding="6,1"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    IsVisible="{Binding ShowConnectAction}"
                                                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ConnectConnectionEntryCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              x:Name="MainPanelsGrid"
              RowDefinitions="*,Auto"
              ColumnSpacing="0"
              RowSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding LocalPanelColumnWidth}" MinWidth="280"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*" MinWidth="280"/>
            </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.Column="0"
                Margin="0,0,4,0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="6">
            <Grid RowDefinitions="Auto,*"
                  RowSpacing="4">
                <Grid Grid.Row="0"
                      Grid.RowSpan="2"
                      RowDefinitions="Auto,*"
                      RowSpacing="4">
                    <Grid Grid.Row="0"
                          ColumnDefinitions="Auto,Auto,*"
                          ColumnSpacing="4">
                        <Border Grid.Column="0"
                                MinWidth="128"
                                Background="{DynamicResource SystemControlChromeMediumLowBrush}"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="6,2">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       Text="{Binding LeftStorageStatus}"/>
                        </Border>
                        <ComboBox Grid.Column="1"
                                  FontSize="11"
                                  MinHeight="0"
                                  ItemsSource="{Binding ConnectedDevices}"
                                  SelectedItem="{Binding SelectedLeftDevice, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="models:ConnectedDevice">
                                    <TextBlock Text="{Binding Label}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Border Grid.Column="2"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="4,2">
                            <TextBox x:Name="LocalPathBox"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="11"
                                     MinHeight="0"
                                     Padding="2,1"
                                     Watermark="Sökväg — tryck Enter för att öppna"
                                     Text="{Binding LocalPath, Mode=TwoWay}"
                                     KeyDown="LocalPathBox_KeyDown"/>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1"
                          x:Name="LocalExplorerGrid"
                          ClipToBounds="True"
                          RowDefinitions="*">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{Binding LocalTreeColumnWidth}" MinWidth="80"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Öppna"
                                          Command="{Binding OpenLocalInExplorerCommand}"/>
                                <Separator/>
                                <MenuItem Header="Kopiera och klistra in"
                                          Command="{Binding CopySelectedLocalToRemoteCommand}"/>
                                <MenuItem Header="Klipp ut och klistra in"
                                          Command="{Binding MoveSelectedLocalToRemoteCommand}"/>
                                <Separator/>
                                <MenuItem Header="Ny mapp"
                                          Command="{Binding CreateLocalFolderCommand}"/>
                                <MenuItem Header="Ta bort"
                                          Command="{Binding DeleteSelectedLocalItemCommand}"
                                          IsEnabled="{Binding !IsDeletingLocalItem}"/>
                            </ContextMenu>
                        </Grid.ContextMenu>

                        <Border Grid.Column="0"
                                ZIndex="0"
                                ClipToBounds="True"
                                Padding="0,0,4,0"
                                Background="{DynamicResource SystemControlChromeMediumLowBrush}">
                            <Grid>
                                <TreeView x:Name="LocalTree"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          ItemsSource="{Binding LocalTreeRoots}"
                                          SelectedItem="{Binding SelectedLocalTreeNode, Mode=OneWay}"
                                          SelectedItems="{Binding SelectedLocalTreeNodes, Mode=TwoWay}"
                                          SelectionMode="Multiple"
                                          ItemContainerTheme="{StaticResource CompactRemoteTreeViewItem}"
                                          Tapped="LocalTreeItem_Tapped">
                            <TreeView.Styles>
                                <Style Selector="TreeViewItem" x:DataType="models:LocalTreeNode">
                                    <Setter Property="MinHeight" Value="18"/>
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                    <Setter Property="IsVisible" Value="{Binding !IsPlaceholder}"/>
                                </Style>
                            </TreeView.Styles>
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate DataType="models:LocalTreeNode"
                                                    ItemsSource="{Binding Children}">
                                    <Grid MinHeight="18"
                                          ColumnDefinitions="Auto,Auto"
                                          VerticalAlignment="Center"
                                          IsVisible="{Binding !IsPlaceholder}">
                                        <Border Grid.Column="0"
                                                Width="12"
                                                Height="12"
                                                Margin="0,0,2,0"
                                                VerticalAlignment="Center">
                                            <Path Data="{StaticResource TreeFolderIcon}"
                                                  Fill="#F4B740"
                                                  Stretch="Uniform"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   TextWrapping="NoWrap"
                                                   Text="{Binding Name}"/>
                                    </Grid>
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                            </TreeView>
                                <Canvas x:Name="LocalTreeMarqueeCanvas"
                                        Panel.ZIndex="1"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        ClipToBounds="True"
                                        IsHitTestVisible="False"/>
                            </Grid>
                        </Border>

                        <GridSplitter x:Name="LocalTreeSplitter"
                                      Grid.Column="1"
                                      ZIndex="2"
                                      Width="1"
                                      ResizeDirection="Columns"
                                      Background="#C8C8C8"
                                      DragCompleted="LocalTreeSplitter_DragCompleted"/>

                        <Border Grid.Column="2"
                                ZIndex="1"
                                ClipToBounds="True"
                                Padding="6,0,0,0"
                                Background="{DynamicResource SystemControlChromeMediumLowBrush}">
                            <Grid>
                                <ListBox x:Name="LocalList"
                                         ItemsSource="{Binding LocalEntries}"
                                         SelectedItem="{Binding SelectedLocalEntry, Mode=TwoWay}"
                                         SelectedItems="{Binding SelectedLocalEntries, Mode=TwoWay}"
                                         SelectionMode="Multiple"
                                         Background="Transparent"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.Styles>
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="Padding" Value="2,0"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="MinHeight" Value="18"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                        <Setter Property="Background" Value="{DynamicResource ListBoxItemBackgroundSelected}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource ListBoxItemForegroundSelected}"/>
                                        <Setter Property="CornerRadius" Value="2"/>
                                    </Style>
                                    <Style Selector="ListBoxItem:selected">
                                        <Setter Property="Background" Value="{DynamicResource ListBoxItemBackgroundSelected}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource ListBoxItemForegroundSelected}"/>
                                    </Style>
                                    <Style Selector="ListBoxItem:selected Border.selection-surface">
                                        <Setter Property="Background" Value="#A00078D7"/>
                                    </Style>
                                    <Style Selector="ListBoxItem.marquee-selected Border.selection-surface">
                                        <Setter Property="Background" Value="#A00078D7"/>
                                    </Style>
                                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="{DynamicResource ListBoxItemBackgroundPointerOver}"/>
                                        <Setter Property="CornerRadius" Value="2"/>
                                    </Style>
                                </ListBox.Styles>
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:LocalEntry">
                                        <Border Classes="selection-surface"
                                                Background="Transparent"
                                                CornerRadius="2"
                                                Height="18"
                                                Margin="1,0"
                                                ToolTip.Tip="{Binding Name}">
                                            <Grid ColumnDefinitions="Auto,*">
                                                <Panel Grid.Column="0"
                                                       Width="14"
                                                       Height="14"
                                                       Margin="0,0,5,0"
                                                       VerticalAlignment="Center">
                                                    <Path IsVisible="{Binding IsDirectory}"
                                                          Data="{StaticResource RemoteFolderIcon}"
                                                          Fill="#F4B740"
                                                          Stretch="Uniform"/>
                                                    <Panel IsVisible="{Binding !IsDirectory}">
                                                        <Path Data="{StaticResource RemoteFileIcon}"
                                                              Fill="#F5F5F5"
                                                              Stroke="#9E9E9E"
                                                              StrokeThickness="0.8"
                                                              Stretch="Uniform"/>
                                                        <Path Data="{StaticResource RemoteFileFoldIcon}"
                                                              Fill="#BDBDBD"
                                                              Stretch="Uniform"/>
                                                    </Panel>
                                                </Panel>
                                                <TextBlock Grid.Column="1"
                                                           VerticalAlignment="Center"
                                                           FontSize="11"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding Name}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                                <Canvas x:Name="LocalListMarqueeCanvas"
                                        Panel.ZIndex="1"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        ClipToBounds="True"
                                        IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <GridSplitter x:Name="MainPanelSplitter"
                      Grid.Row="0"
                      Grid.RowSpan="2"
                      Grid.Column="1"
                      ZIndex="2"
                      Width="30"
                      HorizontalAlignment="Stretch"
                      ResizeDirection="Columns"
                      Background="Transparent"
                      DragCompleted="MainPanelSplitter_DragCompleted"/>

        <Border Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="1"
                ZIndex="1"
                Width="8"
                HorizontalAlignment="Center"
                Margin="0,38,0,0"
                Background="#C8C8C8"
                IsHitTestVisible="False"/>

        <ToggleButton Grid.Row="0"
                      Grid.Column="1"
                      ZIndex="3"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Top"
                      Margin="0,8,0,0"
                      Theme="{StaticResource ConnectionPanelChevron}"
                      IsChecked="{Binding IsConnectionPanelExpanded, Mode=TwoWay}"
                      ToolTip.Tip="Visa/dölj anslutningar"/>

        <Border Grid.Row="0"
                Grid.Column="2"
                Margin="4,0,0,0"
                x:Name="RemotePanel"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="6">
            <Grid RowDefinitions="Auto,*"
                  RowSpacing="4">
                <Grid Grid.Row="0"
                      Grid.RowSpan="2"
                      RowDefinitions="Auto,*"
                      RowSpacing="4">
                    <Grid Grid.Row="0"
                          ColumnDefinitions="Auto,Auto,*"
                          ColumnSpacing="4">
                        <Border Grid.Column="0"
                                MinWidth="128"
                                Background="{DynamicResource SystemControlChromeMediumLowBrush}"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="6,2">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       Text="{Binding RightStorageStatus}"/>
                        </Border>
                        <ComboBox Grid.Column="1"
                                  FontSize="11"
                                  MinHeight="0"
                                  ItemsSource="{Binding ConnectedDevices}"
                                  SelectedItem="{Binding SelectedRightDevice, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="models:ConnectedDevice">
                                    <TextBlock Text="{Binding Label}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Border Grid.Column="2"
                                x:Name="RemotePathBorder"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="4,2">
                            <TextBox x:Name="RemotePathBox"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="11"
                                     MinHeight="0"
                                     Padding="2,1"
                                     Watermark="Sökväg — tryck Enter för att öppna"
                                     Text="{Binding RemotePath, Mode=TwoWay}"
                                     KeyDown="RemotePathBox_KeyDown"/>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1"
                          x:Name="RemoteExplorerGrid"
                          ClipToBounds="True"
                          RowDefinitions="*">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{Binding RemoteTreeColumnWidth}" MinWidth="80"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Öppna"
                                          Command="{Binding OpenRemoteInExplorerCommand}"/>
                                <Separator/>
                                <MenuItem Header="Kopiera och klistra in"
                                          Command="{Binding CopySelectedRemoteToLocalCommand}"/>
                                <MenuItem Header="Klipp ut och klistra in"
                                          Command="{Binding MoveSelectedRemoteToLocalCommand}"/>
                                <Separator/>
                                <MenuItem Header="Ny mapp"
                                          Command="{Binding CreateRemoteFolderCommand}"/>
                                <MenuItem Header="Ta bort"
                                          Command="{Binding DeleteSelectedRemoteItemCommand}"
                                          IsEnabled="{Binding !IsDeletingRemoteItem}"/>
                                <Separator/>
                                <MenuItem Header="Ta bort dubbletter"
                                          Command="{Binding FindRemoteDuplicatesCommand}"
                                          IsEnabled="{Binding !IsDeletingDuplicates}"/>
                            </ContextMenu>
                        </Grid.ContextMenu>

                        <Border Grid.Column="0"
                                ZIndex="0"
                                ClipToBounds="True"
                                Padding="0,0,4,0"
                                Background="{DynamicResource SystemControlChromeMediumLowBrush}">
                            <Grid>
                                <TreeView x:Name="RemoteTree"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          ItemsSource="{Binding RemoteTreeRoots}"
                                          SelectedItem="{Binding SelectedRemoteTreeNode, Mode=OneWay}"
                                          SelectedItems="{Binding SelectedRemoteTreeNodes, Mode=TwoWay}"
                                          SelectionMode="Multiple"
                                          ItemContainerTheme="{StaticResource CompactRemoteTreeViewItem}"
                                          Tapped="RemoteTreeItem_Tapped">
                            <TreeView.Styles>
                                <Style Selector="TreeViewItem" x:DataType="models:RemoteTreeNode">
                                    <Setter Property="MinHeight" Value="18"/>
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                    <Setter Property="IsVisible" Value="{Binding !IsPlaceholder}"/>
                                </Style>
                                <Style Selector="TreeViewItem.drop-target /template/ Border#PART_LayoutRoot">
                                    <Setter Property="Background" Value="#55F4B740"/>
                                </Style>
                            </TreeView.Styles>
                            <TreeView.ItemTemplate>
                                <TreeDataTemplate DataType="models:RemoteTreeNode"
                                                    ItemsSource="{Binding Children}">
                                    <Grid MinHeight="18"
                                          ColumnDefinitions="Auto,Auto"
                                          VerticalAlignment="Center"
                                          IsVisible="{Binding !IsPlaceholder}">
                                        <Border Grid.Column="0"
                                                Width="12"
                                                Height="12"
                                                Margin="0,0,2,0"
                                                VerticalAlignment="Center">
                                            <Panel>
                                                <Path IsVisible="{Binding ShowClosedFolder}"
                                                      Data="{StaticResource TreeFolderIcon}"
                                                      Fill="#F4B740"
                                                      Stretch="Uniform"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"/>
                                                <Path IsVisible="{Binding ShowOpenFolder}"
                                                      Data="{StaticResource TreeFolderOpenIcon}"
                                                      Fill="#F4B740"
                                                      Stretch="Uniform"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"/>
                                            </Panel>
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   TextWrapping="NoWrap"
                                                   Text="{Binding Name}"/>
                                    </Grid>
                                </TreeDataTemplate>
                            </TreeView.ItemTemplate>
                            </TreeView>
                                <Canvas x:Name="RemoteTreeMarqueeCanvas"
                                        Panel.ZIndex="1"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        ClipToBounds="True"
                                        IsHitTestVisible="False"/>
                            </Grid>
                        </Border>

                        <GridSplitter x:Name="RemoteTreeSplitter"
                                      Grid.Column="1"
                                      ZIndex="2"
                                      Width="1"
                                      ResizeDirection="Columns"
                                      Background="#C8C8C8"
                                      DragCompleted="RemoteTreeSplitter_DragCompleted"/>

                        <Border Grid.Column="2"
                                ZIndex="1"
                                ClipToBounds="True"
                                Padding="6,0,0,0"
                                Background="{DynamicResource SystemControlChromeMediumLowBrush}">
                            <Grid>
                                <ListBox x:Name="RemoteList"
                                         ItemsSource="{Binding RemoteEntries}"
                                         SelectedItem="{Binding SelectedRemoteEntry, Mode=TwoWay}"
                                         SelectedItems="{Binding SelectedRemoteEntries, Mode=TwoWay}"
                                         SelectionMode="Multiple"
                                         Background="Transparent"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.Styles>
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="Padding" Value="2,0"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="MinHeight" Value="18"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                        <Setter Property="Background" Value="{DynamicResource ListBoxItemBackgroundSelected}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource ListBoxItemForegroundSelected}"/>
                                        <Setter Property="CornerRadius" Value="2"/>
                                    </Style>
                                    <Style Selector="ListBoxItem:selected">
                                        <Setter Property="Background" Value="{DynamicResource ListBoxItemBackgroundSelected}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource ListBoxItemForegroundSelected}"/>
                                    </Style>
                                    <Style Selector="ListBoxItem:selected Border.selection-surface">
                                        <Setter Property="Background" Value="#A00078D7"/>
                                    </Style>
                                    <Style Selector="ListBoxItem.marquee-selected Border.selection-surface">
                                        <Setter Property="Background" Value="#A00078D7"/>
                                    </Style>
                                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="{DynamicResource ListBoxItemBackgroundPointerOver}"/>
                                        <Setter Property="CornerRadius" Value="2"/>
                                    </Style>
                                    <Style Selector="ListBoxItem.drop-target /template/ ContentPresenter">
                                        <Setter Property="Background" Value="#55F4B740"/>
                                        <Setter Property="CornerRadius" Value="2"/>
                                    </Style>
                                    <Style Selector="ListBoxItem.drop-target">
                                        <Setter Property="Background" Value="#66F4B740"/>
                                    </Style>
                                </ListBox.Styles>
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:RemoteEntry">
                                        <Border Classes="selection-surface"
                                                Background="Transparent"
                                                CornerRadius="2"
                                                Height="18"
                                                Margin="1,0"
                                                ToolTip.Tip="{Binding Name}"
                                                DoubleTapped="RemoteItem_DoubleTapped">
                                            <Grid ColumnDefinitions="Auto,*">
                                                <Panel Grid.Column="0"
                                                       Width="14"
                                                       Height="14"
                                                       Margin="0,0,5,0"
                                                       VerticalAlignment="Center">
                                                    <Path IsVisible="{Binding ShowClosedFolder}"
                                                          Data="{StaticResource RemoteFolderIcon}"
                                                          Fill="#F4B740"
                                                          Stretch="Uniform"/>
                                                    <Path IsVisible="{Binding ShowOpenFolder}"
                                                          Data="{StaticResource RemoteFolderOpenIcon}"
                                                          Fill="#F4B740"
                                                          Stretch="Uniform"/>
                                                    <Panel IsVisible="{Binding !IsDirectory}">
                                                        <Path Data="{StaticResource RemoteFileIcon}"
                                                              Fill="#F5F5F5"
                                                              Stroke="#9E9E9E"
                                                              StrokeThickness="0.8"
                                                              Stretch="Uniform"/>
                                                        <Path Data="{StaticResource RemoteFileFoldIcon}"
                                                              Fill="#BDBDBD"
                                                              Stretch="Uniform"/>
                                                    </Panel>
                                                </Panel>
                                                <TextBlock Grid.Column="1"
                                                           VerticalAlignment="Center"
                                                           FontSize="11"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding Name}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                                <Canvas x:Name="RemoteListMarqueeCanvas"
                                        Panel.ZIndex="1"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        ClipToBounds="True"
                                        IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="0"
                MinHeight="32"
                Margin="0,0,4,0"
                IsVisible="{Binding !IsTransferring}"
                Background="{DynamicResource SystemControlChromeMediumLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8,6">
            <TextBlock FontSize="11"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Text="{Binding LeftStatus}"/>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="2"
                MinHeight="32"
                Margin="4,0,0,0"
                IsVisible="{Binding !IsTransferring}"
                Background="{DynamicResource SystemControlChromeMediumLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8,6">
            <TextBlock FontSize="11"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Text="{Binding RightStatus}"/>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                ZIndex="3"
                MinHeight="32"
                IsVisible="{Binding IsTransferring}"
                Background="{DynamicResource SystemControlChromeMediumLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8,6">
            <Grid RowDefinitions="Auto,Auto"
                  RowSpacing="4">
                <TextBlock Grid.Row="0"
                           FontSize="11"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Text="{Binding Status}"/>
                <Grid Grid.Row="1"
                      ColumnDefinitions="*,Auto,Auto"
                      ColumnSpacing="10">
                    <ProgressBar Grid.Column="0"
                                 Minimum="0"
                                 Maximum="100"
                                 Height="6"
                                 VerticalAlignment="Center"
                                 Value="{Binding ProgressValue}"/>
                    <TextBlock Grid.Column="1"
                               MinWidth="150"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Text="{Binding ProgressText}"/>
                    <Button Grid.Column="2"
                            Width="24"
                            Height="24"
                            Padding="0"
                            VerticalAlignment="Center"
                            Command="{Binding CancelTransferCommand}"
                            ToolTip.Tip="Avbryt överföring">
                        <Path Data="{StaticResource CancelTransferIcon}"
                              Stroke="{DynamicResource SystemControlForegroundBaseHighBrush}"
                              StrokeThickness="1.6"
                              StrokeLineCap="Round"
                              Stretch="Uniform"
                              Width="10"
                              Height="10"/>
                    </Button>
                </Grid>
            </Grid>
        </Border>
        </Grid>
    </Grid>
</Window>
